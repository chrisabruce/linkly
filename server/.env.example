# Linkly Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------------------
# REQUIRED
# -------------------------------------------------------

# Application title (displayed in nav, page titles, and footer)
# APP_TITLE=Linkly

# Secret key for signing JWT auth tokens (use a long random string)
JWT_SECRET=change-me-to-a-random-secret

# -------------------------------------------------------
# SEED ADMIN (optional)
# -------------------------------------------------------
# If set, an admin user will be created on first run (when the database is empty).
# If not set, the first user to register will automatically become the admin.

# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme

# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------

# SQLite database file path
DATABASE_URL=sqlite:./linkly.db

# -------------------------------------------------------
# SERVER
# -------------------------------------------------------

# Host to bind to (0.0.0.0 listens on all interfaces)
HOST=0.0.0.0

# Port to listen on
PORT=3000

# Public base URL (used to generate short links — no trailing slash)
BASE_URL=http://localhost:3000

# URL to redirect visitors to when they hit the root path "/"
# Admins must navigate directly to /admin to access the management panel
ROOT_REDIRECT_URL=https://secedastudios.com

# -------------------------------------------------------
# AUTH
# -------------------------------------------------------

# How long auth tokens last (in hours)
SESSION_DURATION_HOURS=24

# -------------------------------------------------------
# S3 (optional — enables image uploads for links pages)
# -------------------------------------------------------

# S3_BUCKET=linkly-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=secret...

# -------------------------------------------------------
# UNSPLASH (optional — enables background image search for links pages)
# -------------------------------------------------------

# UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# -------------------------------------------------------
# LOGGING
# -------------------------------------------------------

# Log level: error | warn | info | debug | trace
RUST_LOG=linkly=info,tower_http=info
